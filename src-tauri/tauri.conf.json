  {
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "The Auto Print",
    "version": "0.1.0",
    "identifier": "com.theautoprint.auto-printer",
    "build": {
      "frontendDist": "../src"
    },
    "app": {
      "withGlobalTauri": true,
      "windows": [
        {
          "title": "",
          "width": 1100,
          "height": 720,
          "minWidth": 600,
          "minHeight": 300,
          "center": true,
          "decorations": true,
          "resizable": true,
          "titleBarStyle": "Transparent"
        }
      ],
      "security": {
        "csp": null
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "resources/pdfium.dll"
      ],
      "windows": {
        "webviewInstallMode": {
          "type": "downloadBootstrapper",
          "silent": true
        },
        "nsis": {
          "installerHooks": "./hooks.nsh"
        }
      }
    }
  }
